# Database
DATABASE_URL="postgresql://user:password@host.neon.tech/dbname?sslmode=require"
DATABASE_URL_UNPOOLED="postgresql://user:password@host.neon.tech/dbname?sslmode=require"
DATABASE_TIMEOUT_MS="8000"

# Auth
AUTH_SECRET="generate-with-openssl-rand-base64-32"
APP_URL="http://localhost:3000"
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# First admin bootstrap / seed
BOOTSTRAP_ADMIN_USERNAME="admin"
BOOTSTRAP_ADMIN_DISPLAY_NAME="Administrador"
BOOTSTRAP_ADMIN_PASSWORD=""
BOOTSTRAP_SECRET="generate-another-secret"

# Vercel Cron authentication
CRON_SECRET="generate-another-secret"

# Email notifications
# The app keeps saving tickets even when email is not configured.

# Gmail SMTP with a Google app password.
GMAIL_USER="your.account@gmail.com"
GMAIL_APP_PASSWORD="xxxx xxxx xxxx xxxx"

# General recipients: MKT, PF, and fallback for any area.
NOTIFICATION_TO_EMAILS="person1@example.com,person2@example.com"

# TI-specific recipients. If empty, TI falls back to NOTIFICATION_TO_EMAILS.
NOTIFICATION_TI_EMAILS="ti1@example.com,ti2@example.com"

EMAIL_TIMEOUT_MS="6000"
