{
  "name": "helper",
  "version": "0.2.9",
  "private": true,
  "packageManager": "pnpm@11.15.1",
  "engines": {
    "node": ">=24.15.0 <25"
  },
  "scripts": {
    "dev": "next dev",
    "build": "pnpm db:schema:check && node scripts/next-build.mjs",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit --incremental false",
    "test": "tsx --test tests/*.test.ts",
    "test:watch": "tsx --test --watch tests/*.test.ts",
    "test:smoke": "pnpm build && node scripts/smoke.mjs",
    "test:smoke:built": "node scripts/smoke.mjs",
    "test:e2e": "node scripts/e2e-playwright.mjs",
    "icons": "node scripts/generate-icons.mjs",
    "db:schema:check": "tsx scripts/validate-schema.ts",
    "db:check": "tsx --env-file=.env scripts/check-db.ts",
    "db:setup": "tsx --env-file=.env scripts/setup-db.ts",
    "db:seed": "tsx --env-file=.env src/db/seed.ts"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/utilities": "^3.2.2",
    "@hookform/resolvers": "^5.4.0",
    "@neondatabase/serverless": "^1.1.0",
    "@radix-ui/react-avatar": "^1.2.3",
    "@radix-ui/react-dialog": "^1.1.20",
    "@radix-ui/react-dropdown-menu": "^2.1.21",
    "@radix-ui/react-label": "^2.1.12",
    "@radix-ui/react-scroll-area": "^1.2.15",
    "@radix-ui/react-select": "^2.3.4",
    "@radix-ui/react-separator": "^1.1.12",
    "@radix-ui/react-slot": "^1.3.0",
    "@radix-ui/react-tabs": "^1.1.18",
    "@radix-ui/react-tooltip": "^1.2.13",
    "bcryptjs": "^3.0.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.4.0",
    "date-fns-tz": "^3.2.0",
    "drizzle-orm": "^0.45.2",
    "jose": "6.2.3",
    "lucide-react": "1.25.0",
    "next": "^16.2.11",
    "react": "^19.2.8",
    "react-dom": "^19.2.8",
    "react-hook-form": "^7.82.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "web-push": "^3.6.7",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@next/eslint-plugin-next": "^16.2.11",
    "@playwright/test": "1.61.1",
    "@tailwindcss/postcss": "^4.3.3",
    "@types/node": "24.13.3",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/web-push": "^3.6.4",
    "eslint": "^10.7.0",
    "postcss": "8.5.21",
    "tailwindcss": "^4.3.3",
    "tsx": "^4.23.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "8.65.0"
  },
  "license": "MIT"
}
